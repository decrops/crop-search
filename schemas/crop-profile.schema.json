{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crop-search.local/schemas/crop-profile.schema.json",
  "title": "CropProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["crop_id", "label", "crop_group", "aliases"],
  "properties": {
    "crop_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "label": {
      "type": "string",
      "minLength": 2
    },
    "crop_group": {
      "type": "string",
      "minLength": 3
    },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "scientific_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "growth_stage_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "production_context_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_bias_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bbch_stage_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["local_term", "bbch_min", "bbch_max"],
        "properties": {
          "local_term": {
            "type": "string"
          },
          "bbch_min": {
            "type": "integer",
            "minimum": 0,
            "maximum": 99
          },
          "bbch_max": {
            "type": "integer",
            "minimum": 0,
            "maximum": 99
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "source_note": {
            "type": "string"
          }
        }
      }
    },
    "crop_parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["parameter_id"],
        "properties": {
          "parameter_id": {
            "type": "string"
          }
        }
      }
    }
  }
}
