{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crop-search.local/schemas/crop-relationship-query-plan.schema.json",
  "title": "CropRelationshipQueryPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "query_kind",
    "relationship_vocabulary_version",
    "crop_count",
    "matrix_cell_count",
    "planned_pair_count",
    "relationship_modes",
    "source_tier_ids",
    "queries_per_pair",
    "query_count",
    "truncated",
    "queries"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "query_kind": {
      "type": "string",
      "const": "crop_relationship"
    },
    "relationship_vocabulary_version": {
      "type": "string"
    },
    "crop_count": {
      "type": "integer",
      "minimum": 1
    },
    "matrix_cell_count": {
      "type": "integer",
      "minimum": 1
    },
    "planned_pair_count": {
      "type": "integer",
      "minimum": 1
    },
    "relationship_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_tier_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "queries_per_pair": {
      "type": "integer",
      "minimum": 1
    },
    "query_count": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    },
    "queries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/query_item"
      }
    }
  },
  "$defs": {
    "query_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_kind",
        "query",
        "subject_crop_id",
        "object_crop_id",
        "subject_crop_label",
        "object_crop_label",
        "relationship_mode",
        "relationship_subtype",
        "directionality",
        "ordered_pair_key",
        "canonical_relationship_key",
        "source_tier_id",
        "source_tier_label"
      ],
      "properties": {
        "query_kind": {
          "type": "string",
          "const": "crop_relationship"
        },
        "query": {
          "type": "string",
          "minLength": 3
        },
        "subject_crop_id": {
          "type": "string"
        },
        "object_crop_id": {
          "type": "string"
        },
        "subject_crop_label": {
          "type": "string"
        },
        "object_crop_label": {
          "type": "string"
        },
        "relationship_mode": {
          "type": "string"
        },
        "relationship_subtype": {
          "type": "string"
        },
        "directionality": {
          "type": "string",
          "enum": ["directional", "symmetric"]
        },
        "ordered_pair_key": {
          "type": "string"
        },
        "canonical_relationship_key": {
          "type": "string"
        },
        "source_tier_id": {
          "type": "string"
        },
        "source_tier_label": {
          "type": "string"
        }
      }
    }
  }
}
