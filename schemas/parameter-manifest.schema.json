{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crop-search.local/schemas/parameter-manifest.schema.json",
  "title": "ParameterManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "scope", "parameters"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "parameter_id",
          "label",
          "family",
          "category",
          "value_type",
          "normalized_attribute",
          "normalized_attribute_subtype",
          "search_aliases",
          "evidence_patterns",
          "review_policy"
        ],
        "properties": {
          "parameter_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
          },
          "label": {
            "type": "string",
            "minLength": 3
          },
          "family": {
            "type": "string",
            "minLength": 3
          },
          "category": {
            "type": "string",
            "enum": [
              "physiological_parameter",
              "management_recommendation",
              "environmental_response",
              "phenology_parameter",
              "quality_parameter"
            ]
          },
          "value_type": {
            "type": "string",
            "enum": ["numeric", "range", "text", "boolean", "numeric_or_range", "text_or_numeric"]
          },
          "canonical_units": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applies_to_crop_groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "normalized_attribute": {
            "type": "string",
            "minLength": 3
          },
          "normalized_attribute_subtype": {
            "type": "string",
            "minLength": 3
          },
          "search_aliases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "evidence_patterns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "management_relevance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_scope": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["crop", "region", "growth_stage", "season", "cultivar", "management_system"]
            }
          },
          "review_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["allow_canonical", "conflict_key", "merge_if_values_overlap"],
            "properties": {
              "allow_canonical": {
                "type": "boolean"
              },
              "conflict_key": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "merge_if_values_overlap": {
                "type": "boolean"
              }
            }
          },
          "domain": {
            "type": "string",
            "enum": [
              "variety_cultivar", "climate_site", "soil_requirements", "soil_prep_tillage",
              "planting_establishment", "water_management", "nutrient_management", "crop_protection",
              "growth_monitoring", "stress_abiotic", "harvest", "post_harvest_quality", "economics"
            ]
          },
          "parameter_kind": {
            "type": "string",
            "enum": ["trait", "operation"]
          },
          "concept_scope": {
            "type": "string",
            "enum": ["universal", "crop_group", "crop"]
          },
          "decision": {
            "type": "string"
          },
          "requires_stage_context": {
            "type": "boolean"
          },
          "implementation_status": {
            "type": "string",
            "enum": ["active", "stub", "deferred"]
          },
          "query_units": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "query_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stage_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected_value_shape": {
            "type": "string",
            "enum": ["numeric", "range", "numeric_range", "date_window", "stage", "category", "boolean", "text"]
          },
          "expected_scope": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["crop", "crop_group", "region", "growth_stage", "season", "cultivar", "management_system", "organism", "method", "price_year"]
            }
          },
          "false_positive_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "extraction_notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
