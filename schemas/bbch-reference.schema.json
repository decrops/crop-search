{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crop-search.local/schemas/bbch-reference.schema.json",
  "title": "BBCHReference",
  "type": "object",
  "additionalProperties": false,
  "required": ["reference", "principal_stages"],
  "properties": {
    "reference": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "principal_stages": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "name"],
        "properties": {
          "code": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "name": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  }
}
