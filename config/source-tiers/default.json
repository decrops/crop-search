        "usda.gov",
        "ahdb.org.uk",
        "grdc.com.au",
        "canolacouncil.org",
        "gov.uk",
        "agric.wa.gov.au",
        "dpi.nsw.gov.au"
      ],
      "title_terms": [
        "extension",
        "agronomy",
        "production guide",
        "management guide",
        "crop guide",
        "handbook"
      ],
      "access_policy": "open_full_text_preferred",
      "notes": "High practical value but location-specific; do not over-generalize regional recommendations."
    },
    {
      "tier_id": "industry_grower_guide",
      "label": "Industry and Grower Guides",
      "priority": 5,
      "evidence_role": "Practice-oriented guidance, useful when provenance and bias are tracked.",
      "trust_weight": 0.55,
      "query_terms": [
